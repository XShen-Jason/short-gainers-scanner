# ==========================================
# Short Gainers Screener - 环境变量配置
# ==========================================

# --- OKX API 配置 ---
# OKX 公开接口的基础 URL。
# 默认值: https://www.okx.com
OKX_BASE_URL=https://www.okx.com

# --- Supabase 数据库配置 ---
# 你在 Supabase 项目设置 -> API 中找到的 Project URL。
SUPABASE_URL=https://your-project.supabase.co
# 你在 Supabase 项目设置 -> API 中找到的 service_role key。
# 必须使用 service_role 以绕过 RLS (Row Level Security)。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- 业务逻辑配置 ---
# 每次任务处理涨幅榜前 N 名的交易对。
# 建议值: 20-50
TOP_N=50

# 计算 Rolling High/Low 指标时的K线窗口大小（例如最近 50 根K线）。
# 对应指标层计算。
ROLLING_WINDOW=50

# 是否记录历史数据。如果为 false，可能只保留最新一帧（根据具体业务实现）。
TRACK_HISTORY=true

# 进入筛选名单的最小涨幅百分比阈值。
# 例如: 3 表示只处理 24h 涨幅超过 3% 的币种。
MIN_CHANGE_PERCENT=3

# 需要抓取的K线周期，用逗号隔开。
# 支持值: 1m, 3m, 5m, 15m, 30m, 1H, 2H, 4H, 6H, 12H, 1D, 1W, 1M
TIMEFRAMES=5m,15m,1h,4h,1d
