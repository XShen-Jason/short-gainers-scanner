# --- VPS 运行配置 ---
# 服务运行端口 (默认 3000)
PORT=3000
# 允许外部访问 (0.0.0.0 表示监听所有网卡)
HOST=0.0.0.0

# --- OKX API 配置 ---
OKX_BASE_URL=https://www.okx.com

# --- Supabase 数据库配置 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- 业务逻辑配置 ---
# 每次处理前 N 名币种
TOP_N=50
# 触发追踪的最小涨幅百分比
MIN_CHANGE_PERCENT=3
# 抓取周期 (Cron 表达式: "*/30 * * * *" 表示每 30 分钟一次)
CRON_SCHEDULE="*/30 * * * *"
# 追踪锁定时间 (小时): 一个币种在离开榜单后，继续追踪多长时间
TRACKING_DURATION_HOURS=24
# K线统计周期
TIMEFRAMES=5m,15m,1h,4h,1d
# 指标计算窗口
ROLLING_WINDOW=50
